        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml ITIL_HelpDesk_Architecture\n&#39; Better colors for draw.io / diagrams.net\nskinparam backgroundColor #F8F9FA\nskinparam shadowing false\nskinparam defaultFontName Arial\nskinparam dpi 150\n\nskinparam packageStyle rectangle\nskinparam packageBorderColor #444444\nskinparam packageFontColor #222222\nskinparam packageBackgroundColor #E9ECEF\n\nskinparam componentStyle rectangle\nskinparam componentBorderColor #333333\nskinparam componentFontColor #111111\nskinparam componentBackgroundColor #FFFFFF\n\nskinparam arrowColor #555555\nskinparam ArrowThickness 1.2\n\nskinparam noteBackgroundColor #FFF8C6\nskinparam noteBorderColor #C9B458\nskinparam noteFontColor #222222\n\ntitle ITIL HelpDesk Architecture\n\npackage \&quot;Frontend - Angular\&quot; #D6EAF8 {\n\n    package \&quot;Pages\&quot; #AED6F1 {\n        component Dashboard #5DADE2\n        component Tickets #5DADE2\n        component TicketDetail #5DADE2\n        component Articles #5DADE2\n        component ArticleDetail #5DADE2\n        component SLAManagement #5DADE2\n        component Contact #5DADE2\n    }\n\n    package \&quot;Modals &amp; Forms\&quot; #D5F5E3 {\n        component CreateTicketModal #58D68D\n        component CreateSLAForm #58D68D\n        component CommentForm #58D68D\n    }\n\n    package \&quot;Shared Components\&quot; #FCF3CF {\n        component Sidebar #F4D03F\n        component Footer #F4D03F\n        component MainLayout #F4D03F\n    }\n\n    package \&quot;Services\&quot; #FADBD8 {\n        component TicketService #EC7063\n        component ArticleService #EC7063\n        component SLAService #EC7063\n        component CommentsService #EC7063\n        component SupportersService #EC7063\n        component CategoriesService #EC7063\n        component ProfileRoleService #EC7063\n    }\n}\n\npackage \&quot;Backend - Express.js\&quot; #E8DAEF {\n\n    package \&quot;Routes\&quot; #D2B4DE {\n        component TicketsRoute #AF7AC5\n        component ArticlesRoute #AF7AC5\n        component SLAsRoute #AF7AC5\n        component CommentsRoute #AF7AC5\n        component SupportersRoute #AF7AC5\n        component CategoriesRoute #AF7AC5\n    }\n\n    database MySQL_Database #A3E4D7\n}\n\ncomponent HttpClient #F5CBA7\n\n&#39; Page to Service Dependencies\nDashboard --&gt; TicketService\nDashboard --&gt; ArticleService\nDashboard --&gt; SLAService\nDashboard --&gt; ProfileRoleService\n\nTickets --&gt; TicketService\nTickets --&gt; CategoriesService\nTickets --&gt; ProfileRoleService\nTickets --&gt; CreateTicketModal\n\nTicketDetail --&gt; TicketService\nTicketDetail --&gt; CommentsService\nTicketDetail --&gt; ProfileRoleService\nTicketDetail --&gt; CommentForm\n\nArticles --&gt; ArticleService\nArticleDetail --&gt; ArticleService\n\nSLAManagement --&gt; SLAService\nSLAManagement --&gt; CreateSLAForm\n\nContact --&gt; SupportersService\n\nSidebar --&gt; ProfileRoleService\nMainLayout --&gt; Sidebar\nMainLayout --&gt; Footer\n\n&#39; Modal Dependencies\nCreateTicketModal --&gt; TicketService\nCreateTicketModal --&gt; CategoriesService\nCreateTicketModal --&gt; ProfileRoleService\n\nCreateSLAForm --&gt; SLAService\nCommentForm --&gt; CommentsService\nCommentForm --&gt; ProfileRoleService\n\n&#39; Service to HTTP\nTicketService --&gt; HttpClient\nArticleService --&gt; HttpClient\nSLAService --&gt; HttpClient\nCommentsService --&gt; HttpClient\nSupportersService --&gt; HttpClient\nCategoriesService --&gt; HttpClient\n\n&#39; HTTP to Routes\nHttpClient --&gt; TicketsRoute\nHttpClient --&gt; ArticlesRoute\nHttpClient --&gt; SLAsRoute\nHttpClient --&gt; CommentsRoute\nHttpClient --&gt; SupportersRoute\nHttpClient --&gt; CategoriesRoute\n\n&#39; Routes to Database\nTicketsRoute --&gt; MySQL_Database\nArticlesRoute --&gt; MySQL_Database\nSLAsRoute --&gt; MySQL_Database\nCommentsRoute --&gt; MySQL_Database\nSupportersRoute --&gt; MySQL_Database\nCategoriesRoute --&gt; MySQL_Database\n\